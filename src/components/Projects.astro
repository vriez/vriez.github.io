---
const projects = [
  {
    tag: 'AI Platform',
    title: 'Atlas',
    description: 'AI decision-support platform for crisis management. Structures situational awareness, generates response options, and coordinates action — with a human approving every step.',
    tech: ['AI', 'OODA Loop', 'Autonomous Systems'],
    highlight: 'Presented at the Austrian Parliament — Language & Intelligence 2025',
    link: 'https://www.zfrk.org/neuigkeiten/language-intelligence-2025-zrk-mit-starken-beitraegen-im-parlament-vertreten/',
  },
  {
    tag: 'Knowledge Systems',
    title: 'RAG Knowledge Graphs',
    description: 'RAG system backed by Neo4j knowledge graphs. Staff at 50+ restaurant locations query operational data — recipes, SOPs, inventory rules — in natural language, without writing a single database query.',
    tech: ['RAG', 'Neo4j', 'LLM', 'Kafka', 'Kubernetes'],
    highlight: 'MSc thesis research applied to production systems',
  },
  {
    tag: 'Autonomous Systems',
    title: 'OODA Loop UAV Engine',
    description: 'Real-time decision engine for autonomous drones — embedded Rust running on Arduino and Pixhawk hardware. The drone observes, orients, decides, and acts in millisecond loops without ground-station intervention.',
    tech: ['Rust', 'Arduino', 'Pixhawk', 'Real-time Systems'],
    highlight: 'Ongoing research — USP Aeronautical Systems',
  },
  {
    tag: 'Computer Vision',
    title: 'OCR with RLHF',
    description: 'Document OCR trained with RLHF to handle messy, real-world scans — handwritten forms, stamps, and certificates. Extracts structured fields where conventional OCR fails.',
    tech: ['RLHF', 'Computer Vision', 'PyTorch', 'OCR'],
    highlight: 'Replaced manual data entry in production',
  },
];
---

<section class="projects" id="projects">
  <div class="container">
    <div class="projects-header fade-in">
      <p class="section-label">Selected Projects</p>
      <h2 class="section-title">What I've built</h2>
      <p class="section-subtitle">
        Selected projects from industry and academia.
      </p>
    </div>

    <div class="carousel-layout fade-in">
      <!-- Gallery nav -->
      <nav class="gallery" id="projects-gallery" aria-label="Project navigation">
        {projects.map((project, i) => (
          <button
            class={`gallery-item ${i === 0 ? 'active' : ''}`}
            data-index={i}
          >
            <span class="gallery-icon">
              {/* Using the first letter of the tag as icon for now */}
              {project.tag.charAt(0)}
            </span>
            <span class="gallery-text">
              <span class="gallery-name">{project.tag}</span>
              <span class="gallery-status">
                {/* Using a simple status indicator */}
                <span class="dot"></span>
              </span>
            </span>
            <span class="gallery-indicator" />
          </button>
        ))}
      </nav>

      <!-- Carousel -->
      <div class="carousel-main">
        <div class="carousel" id="projects-carousel" tabindex="0" role="region" aria-label="Project carousel">
          <div class="carousel-track" id="projects-track" aria-live="polite">
            {projects.map((project) => (
              <article class="project-card">
                <div class="project-tag">{project.tag}</div>
                <h3 class="project-title">
                  {project.link ? (
                    <a href={project.link} target="_blank" rel="noopener noreferrer">
                      {project.title}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                  ) : project.title}
                </h3>
                <p class="project-description">{project.description}</p>
                {project.highlight && (
                  <p class="project-highlight">{project.highlight}</p>
                )}
                <div class="project-tech">
                  {project.tech.map((t) => (
                    <span class="tech-tag">{t}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="carousel-controls">
          <div class="carousel-dots" id="projects-dots">
            {projects.map((_, i) => (
              <button
                class={`carousel-dot ${i === 0 ? 'active' : ''}`}
                data-index={i}
                aria-label={`Go to project ${i + 1}`}
              />
            ))}
          </div>
          <div class="carousel-arrows">
            <button class="carousel-arrow pause" id="projects-pause" aria-label="Pause autoplay">
              <svg class="icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
              <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </button>
            <button class="carousel-arrow prev" id="projects-prev" aria-label="Previous project">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="carousel-arrow next" id="projects-next" aria-label="Next project">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .projects {
    padding-inline: 2rem;
    padding-bottom: 4rem;
    background: var(--color-bg-light);
  }

  .projects-header {
    margin-bottom: 3rem;
  }

  /* Layout: gallery left + carousel right */
  .carousel-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* Gallery */
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    position: sticky;
    top: calc(var(--header-height) + 2rem);
  }

  .gallery-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.875rem 1rem;
    border: none;
    background: transparent;
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    position: relative;
    transition: background 0.25s, transform 0.2s;
    font-family: inherit;
  }

  .gallery-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) scaleY(0);
    width: 3px;
    height: 60%;
    border-radius: 0 2px 2px 0;
    background: var(--color-accent);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item.active::before {
    transform: translateY(-50%) scaleY(1);
  }

  .gallery-item:hover {
    background: rgba(var(--color-accent-rgb), 0.05);
  }

  .gallery-item.active {
    background: rgba(var(--color-accent-rgb), 0.08);
  }

  .gallery-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    color: var(--color-text-muted);
    opacity: 0.5;
    transition: color 0.3s, opacity 0.3s;
  }

  .gallery-item.active .gallery-icon {
    color: var(--color-accent);
    opacity: 1;
  }

  .gallery-item:hover .gallery-icon {
    opacity: 0.8;
  }

  .gallery-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .gallery-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: color 0.3s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gallery-item.active .gallery-name {
    color: var(--color-text-dark);
  }

  .gallery-status {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  .gallery-status.available {
    color: var(--color-accent);
  }

  .gallery-item.active .gallery-status {
    opacity: 1;
  }

  .gallery-indicator {
    display: none;
  }

  /* Carousel main area */
  .carousel-main {
    min-width: 0;
  }

  .carousel {
    overflow: hidden;
    border-radius: 12px;
    touch-action: pan-y;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .project-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 340px;
    flex: 0 0 100%;
    min-width: 0;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .project-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-on-light);
    background: var(--color-accent-glow);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    width: fit-content;
    margin-bottom: 1rem;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 0.75rem;
  }

  .project-title a {
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .project-title a:hover {
    color: var(--color-accent);
  }

  .project-title svg {
    opacity: 0.4;
    flex-shrink: 0;
  }

  .project-description {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    flex: 1;
  }

  .project-highlight {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-dim);
    background: var(--color-accent-glow);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    margin-bottom: 1rem;
    border-left: 3px solid var(--color-accent);
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg-light);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  /* Controls */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .carousel-dots {
    display: flex;
    gap: 0.5rem;
  }

  .carousel-dot {
    width: 2rem;
    height: 3px;
    border: none;
    border-radius: 2px;
    background: var(--color-border);
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
    padding: 1rem 0;
    background-clip: content-box;
  }

  .carousel-dot.active {
    background: var(--color-accent);
    background-clip: content-box;
    width: 3rem;
  }

  .carousel-dot:hover:not(.active) {
    background: var(--color-text-muted);
    background-clip: content-box;
  }

  .carousel-arrows {
    display: flex;
    gap: 0.5rem;
  }

  .carousel-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-dark);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s, color 0.2s, opacity 0.2s;
  }

  .carousel-arrow:hover:not(.disabled) {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-text-light);
  }

  .carousel-arrow.disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }

  /* Tablet: collapse sidebar into horizontal strip */
  @media (max-width: 1024px) {
    .carousel-layout {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .gallery {
      flex-direction: row;
      overflow-x: auto;
      gap: 0.25rem;
      position: static;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 0.25rem;
    }

    .gallery::-webkit-scrollbar {
      display: none;
    }

    .gallery-item {
      flex-shrink: 0;
    }

    .gallery-item::before {
      left: 50%;
      top: auto;
      bottom: 0;
      transform: translateX(-50%) scaleX(0);
      width: 60%;
      height: 2px;
      border-radius: 2px 2px 0 0;
    }

    .gallery-item.active::before {
      transform: translateX(-50%) scaleX(1);
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .projects {
      padding-inline: 1.25rem;
    }

    .gallery-item {
      padding: 0.6rem 0.875rem;
      border-radius: var(--radius-md);
    }

    .gallery-icon {
      width: 22px;
      height: 22px;
    }

    .gallery-status {
      display: none;
    }

    .gallery-name {
      font-size: 0.8rem;
    }

    .project-card {
      padding: 2rem 1.5rem;
      min-height: auto;
    }

    .project-title {
      font-size: 1.25rem;
    }

    .project-description {
      font-size: 0.9rem;
    }

    .carousel-arrow {
      width: 44px;
      height: 44px;
    }
  }
</style>

<script>
  const track = document.getElementById('projects-track') as HTMLElement;
  const dots = document.querySelectorAll('#projects-dots .carousel-dot');
  const galleryItems = document.querySelectorAll('#projects-gallery .gallery-item');
  const prevBtn = document.getElementById('projects-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('projects-next') as HTMLButtonElement;
  const total = galleryItems.length;
  let current = 0;
  let startX = 0;
  let isDragging = false;

  function goTo(index: number) {
    current = Math.max(0, Math.min(index, total - 1));
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, i) => dot.classList.toggle('active', i === current));
    galleryItems.forEach((item, i) => item.classList.toggle('active', i === current));
    const atStart = current === 0;
    const atEnd = current === total - 1;
    prevBtn.classList.toggle('disabled', atStart);
    nextBtn.classList.toggle('disabled', atEnd);
    prevBtn.setAttribute('aria-disabled', String(atStart));
    nextBtn.setAttribute('aria-disabled', String(atEnd));
  }

  // Gallery clicks
  galleryItems.forEach((item) => {
    item.addEventListener('click', () => goTo(Number((item as HTMLElement).dataset.index)));
  });

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number((dot as HTMLElement).dataset.index)));
  });

  // Keyboard
  document.getElementById('projects-carousel')!.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });

  // Touch / pointer swipe
  track.addEventListener('pointerdown', (e) => {
    if ((e.target as HTMLElement).closest('a')) return;
    startX = e.clientX;
    isDragging = true;
    track.style.transition = 'none';
    track.setPointerCapture(e.pointerId);
  });

  track.addEventListener('pointerup', (e) => {
    if (!isDragging) return;
    isDragging = false;
    track.style.transition = '';
    const diff = e.clientX - startX;
    if (Math.abs(diff) > 60) {
      goTo(current + (diff < 0 ? 1 : -1));
    } else {
      goTo(current);
    }
  });

  track.addEventListener('pointercancel', () => {
    isDragging = false;
    track.style.transition = '';
    goTo(current);
  });

  // Auto-advance (disabled for prefers-reduced-motion)
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let autoplay: ReturnType<typeof setInterval> | null = null;
  let userPaused = false;
  const pauseBtn = document.getElementById('projects-pause') as HTMLButtonElement;
  const iconPause = pauseBtn.querySelector('.icon-pause') as SVGElement;
  const iconPlay = pauseBtn.querySelector('.icon-play') as SVGElement;

  function startAutoplay() {
    if (prefersReducedMotion || userPaused) return;
    stopAutoplay();
    autoplay = setInterval(() => {
      if (current < total - 1) goTo(current + 1);
      else stopAutoplay();
    }, 5000);
  }

  function stopAutoplay() {
    if (autoplay) { clearInterval(autoplay); autoplay = null; }
  }

  function updatePauseBtn() {
    const paused = userPaused || prefersReducedMotion;
    iconPause.style.display = paused ? 'none' : '';
    iconPlay.style.display = paused ? '' : 'none';
    pauseBtn.setAttribute('aria-label', paused ? 'Play autoplay' : 'Pause autoplay');
  }

  pauseBtn.addEventListener('click', () => {
    userPaused = !userPaused;
    if (userPaused) stopAutoplay();
    else startAutoplay();
    updatePauseBtn();
  });

  const carousel = document.getElementById('projects-carousel')!;
  const layout = carousel.closest('.carousel-layout')!;
  layout.addEventListener('pointerenter', stopAutoplay);
  layout.addEventListener('pointerleave', () => { if (!userPaused) startAutoplay(); });
  layout.addEventListener('focusin', stopAutoplay);
  layout.addEventListener('focusout', () => { if (!userPaused) startAutoplay(); });

  if (prefersReducedMotion) userPaused = true;
  updatePauseBtn();
  startAutoplay();
  goTo(0);
</script>
