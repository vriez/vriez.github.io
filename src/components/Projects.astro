---
const projects = [
  {
    tag: 'AI Platform',
    title: 'Atlas',
    description: 'AI decision-support platform for crisis management. Uses OODA Loop cycles to structure situational awareness, option generation, and response coordination with human oversight.',
    tech: ['AI', 'OODA Loop', 'Autonomous Systems'],
    highlight: 'Presented at the Austrian Parliament — Language & Intelligence 2025',
    link: 'https://www.zfrk.org/neuigkeiten/language-intelligence-2025-zrk-mit-starken-beitraegen-im-parlament-vertreten/',
  },
  {
    tag: 'Knowledge Systems',
    title: 'RAG Knowledge Graphs',
    description: 'RAG system backed by Neo4j knowledge graphs and LLMs. Deployed across 50+ locations for querying structured operational data in natural language.',
    tech: ['RAG', 'Neo4j', 'LLM', 'Kafka', 'Kubernetes'],
    highlight: 'MSc thesis research applied to production systems',
  },
  {
    tag: 'Autonomous Systems',
    title: 'OODA Loop UAV Engine',
    description: 'Real-time decision engine for autonomous drones using embedded Rust on Arduino and Pixhawk hardware. Implements OODA Loop cycles for autonomous flight control.',
    tech: ['Rust', 'Arduino', 'Pixhawk', 'Real-time Systems'],
    highlight: 'Ongoing research — USP Aeronautical Systems',
  },
  {
    tag: 'Computer Vision',
    title: 'OCR with Reinforcement Learning',
    description: 'OCR system trained with Reinforcement Learning for automated document processing. Extracts structured data from scanned forms and certificates.',
    tech: ['RL', 'Computer Vision', 'TensorFlow', 'OCR'],
    highlight: 'Automated document processing pipeline',
  },
];
---

<section class="projects" id="projects">
  <div class="container">
    <div class="projects-header fade-in">
      <div class="projects-header-row">
        <div>
          <p class="section-label">Products & Projects</p>
          <h2 class="section-title">What I've built</h2>
          <p class="section-subtitle">
            From research prototypes to production systems.
          </p>
        </div>
        <div class="carousel-nav">
          <button class="carousel-btn" id="carousel-prev" aria-label="Previous project">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="carousel-btn" id="carousel-next" aria-label="Next project">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
  <div class="carousel-track" id="carousel-track">
    {projects.map((project, i) => (
      <article class="project-card fade-in" style={`transition-delay: ${i * 0.08}s`}>
        <div class="project-tag">{project.tag}</div>
        <h3 class="project-title">
          {project.link ? (
            <a href={project.link} target="_blank" rel="noopener noreferrer">
              {project.title}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          ) : project.title}
        </h3>
        <p class="project-description">{project.description}</p>
        {project.highlight && (
          <p class="project-highlight">{project.highlight}</p>
        )}
        <div class="project-tech">
          {project.tech.map((t) => (
            <span class="tech-tag">{t}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');

  if (track && prevBtn && nextBtn) {
    const getScrollAmount = () => {
      const card = track.querySelector('.project-card') as HTMLElement;
      if (!card) return 400;
      return card.offsetWidth + 24; // card width + gap
    };

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  }
</script>

<style>
  .projects {
    padding: 6rem 0;
    background: var(--color-bg-light);
    overflow: hidden;
  }

  .projects-header {
    margin-bottom: 3rem;
  }

  .projects-header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .carousel-nav {
    display: flex;
    gap: 0.5rem;
  }

  .carousel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-dark);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .carousel-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    padding: 0 max(2rem, calc((100vw - var(--max-width)) / 2 + 2rem));
    padding-bottom: 1rem;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 2rem,
      black calc(100% - 6rem),
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 2rem,
      black calc(100% - 6rem),
      transparent
    );
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .project-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem 1.75rem 2.5rem;
    min-height: 380px;
    width: calc((var(--max-width) - 1.5rem) / 2);
    min-width: 340px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
    scroll-snap-align: start;
  }

  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
  }

  .project-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    width: fit-content;
    margin-bottom: 1rem;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text-dark);
  }

  .project-title a {
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .project-title a:hover {
    color: var(--color-accent);
  }

  .project-title svg {
    opacity: 0.4;
    flex-shrink: 0;
  }

  .project-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .project-highlight {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-dim);
    background: var(--color-accent-glow);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    margin-bottom: 1rem;
    border-left: 3px solid var(--color-accent);
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg-light);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .projects {
      padding: 4rem 0;
    }

    .projects-header {
      padding: 0 2rem;
    }

    .projects-header-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .project-card {
      min-width: 280px;
      min-height: 340px;
    }

    .carousel-track {
      padding: 0 2rem;
      padding-bottom: 1rem;
    }
  }
</style>
