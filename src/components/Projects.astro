---
const projects = [
  {
    tag: 'AI Platform',
    title: 'Atlas',
    description: 'C⁴ISR-inspired platform for crisis management. Human operators and AI agents work together in a collaborative, multi-agent environment — structuring situational awareness, deciding on response options, and executing actions with full human oversight.',
    tech: ['AI', 'OODA Loop', 'Autonomous Systems'],
    highlight: 'Presented at the Austrian Parliament — Language & Intelligence 2025',
    link: 'https://www.zfrk.org/neuigkeiten/language-intelligence-2025-zrk-mit-starken-beitraegen-im-parlament-vertreten/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="currentColor"><path d="M32 4L6 18v28l26 14 26-14V18L32 4zm0 5.2L52.4 19 32 28.8 11.6 19 32 9.2zM10 22.4l20 10.8V54L10 43.2V22.4zm24 10.8l20-10.8v20.8L34 54V33.2z"/></svg>`,
  },
  {
    tag: 'Knowledge Systems',
    title: 'RAG Knowledge Graphs',
    description: 'RAG system built on knowledge graphs to mine scientific literature for overlooked correlations — applied to the relationship between COVID-19 severity, Vitamin D deficiency, and sunscreen use. Users query the knowledge base in natural language through an interactive assistant.',
    tech: ['RAG', 'Knowledge Graphs', 'LLM', 'NLP', 'Text Mining'],
    highlight: 'MSc thesis — UFSCar',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="currentColor"><path d="M30 8.5c-5.2.3-9.5 3-12 7-1.8 2.8-2.5 6.2-2 9.5.1.8-.1 1.5-.5 2.2-1.8 2.8-2.3 6.2-1 9.3 1.2 3 3.8 5.2 6.8 6.2.8.3 1.4.9 1.7 1.7l1.5 4.1c.3.8 1 1.3 1.8 1.5h3.7V30.5c-2-.3-3.5-1-5-2l2.5-3.5c1 .7 2 1 3.2 1h.3V15.5c-1.5-.5-3-1.3-4-2.5l3-3c.5.5 1 .8 1.7 1V8.5zm4 0v2.5c.7-.2 1.2-.5 1.7-1l3 3c-1 1.2-2.5 2-4 2.5V26h.3c1.2 0 2.2-.3 3.2-1l2.5 3.5c-1.5 1-3 1.7-5 2V50h3.7c.8-.2 1.5-.7 1.8-1.5l1.5-4.1c.3-.8.9-1.4 1.7-1.7 3-1 5.6-3.2 6.8-6.2 1.3-3.1.8-6.5-1-9.3-.4-.7-.6-1.4-.5-2.2.5-3.3-.2-6.7-2-9.5-2.5-4-6.8-6.7-12-7z"/></svg>`,
  },
  {
    tag: 'Autonomous Systems',
    title: 'OODA Loop UAV Engine',
    description: 'Fault-tolerant control system for multi-UAV fleets using Boyd\'s OODA loop. When a drone fails mid-mission, the system reallocates orphaned tasks to healthy vehicles while respecting battery, payload, and regulatory constraints — escalating to human operators when autonomous recovery isn\'t safe.',
    tech: ['OODA Loop', 'Multi-Agent Systems', 'Fault Tolerance', 'Mission Planning'],
    highlight: 'Specialization Thesis — EESC-USP Aeronautical Systems',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="currentColor"><circle cx="32" cy="32" r="6"/><circle cx="14" cy="14" r="4"/><circle cx="50" cy="14" r="4"/><circle cx="14" cy="50" r="4"/><circle cx="50" cy="50" r="4"/><path d="M27.8 27.8l-10-10M36.2 27.8l10-10M27.8 36.2l-10 10M36.2 36.2l10 10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/><circle cx="32" cy="8" r="3.5"/><circle cx="32" cy="56" r="3.5"/><circle cx="8" cy="32" r="3.5"/><circle cx="56" cy="32" r="3.5"/><path d="M32 14v12M32 38v12M14 32h12M38 32h12" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/></svg>`,
  },
  {
    tag: 'Computer Vision',
    title: 'OCR with RLHF',
    description: 'Document OCR trained with RLHF to handle messy, real-world scans — handwritten text, stamps, and certificates. Extracts structured data from dense, cluttered documents at industrial scale, with human feedback driving continuous improvement.',
    tech: ['RLHF', 'Computer Vision', 'PyTorch', 'OCR'],
    highlight: 'Replaced manual data entry in production',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="currentColor"><path d="M32 12c-14 0-26 12-26 20s12 20 26 20 26-12 26-20S46 12 32 12zm0 34c-7.7 0-14-6.3-14-14s6.3-14 14-14 14 6.3 14 14-6.3 14-14 14z"/><circle cx="32" cy="32" r="8"/></svg>`,
  },
];
---

<section class="projects" id="projects">
  <div class="container">
    <div class="projects-header fade-in">
      <p class="section-label">Selected Projects</p>
      <h2 class="section-title">What I've built</h2>
      <p class="section-subtitle">
        Selected projects from industry and academia.
      </p>
    </div>

    <div class="carousel-layout fade-in">
      <!-- Gallery nav -->
      <nav class="gallery" id="projects-gallery" aria-label="Project navigation">
        {projects.map((project, i) => (
          <button
            class={`gallery-item ${i === 0 ? 'active' : ''}`}
            data-index={i}
          >
            <span class="gallery-icon">
              {project.icon ? <Fragment set:html={project.icon} /> : project.tag.charAt(0)}
            </span>
            <span class="gallery-text">
              <span class="gallery-name">{project.tag}</span>
              <span class="gallery-status">
                {/* Using a simple status indicator */}
                <span class="dot"></span>
              </span>
            </span>
            <span class="gallery-indicator" />
          </button>
        ))}
      </nav>

      <!-- Carousel -->
      <div class="carousel-main">
        <div class="carousel" id="projects-carousel" tabindex="0" role="region" aria-label="Project carousel">
          <div class="carousel-track" id="projects-track" aria-live="polite">
            {projects.map((project) => (
              <article class="project-card">
                <div class="project-tag">{project.tag}</div>
                <h3 class="project-title">
                  {project.link ? (
                    <a href={project.link} target="_blank" rel="noopener noreferrer">
                      {project.title}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      <span class="sr-only">(opens in new tab)</span>
                    </a>
                  ) : project.title}
                </h3>
                <p class="project-description">{project.description}</p>
                {project.highlight && (
                  <p class="project-highlight">
                    {project.link ? (
                      <a href={project.link} target="_blank" rel="noopener noreferrer">
                        {project.highlight}
                        <span class="sr-only">(opens in new tab)</span>
                      </a>
                    ) : project.highlight}
                  </p>
                )}
                <div class="project-tech">
                  {project.tech.map((t) => (
                    <span class="tech-tag">{t}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="carousel-controls">
          <div class="carousel-dots" id="projects-dots">
            {projects.map((_, i) => (
              <button
                class={`carousel-dot ${i === 0 ? 'active' : ''}`}
                data-index={i}
                aria-label={`Go to project ${i + 1}`}
              />
            ))}
          </div>
          <div class="carousel-arrows">
            <button class="carousel-arrow prev" id="projects-prev" aria-label="Previous project">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="carousel-arrow next" id="projects-next" aria-label="Next project">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .projects {
    padding-inline: var(--space-section-inline);
    padding-bottom: var(--space-2xl);
    background: var(--color-bg-light);
  }

  .projects-header {
    margin-bottom: var(--space-xl);
  }

  .project-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl) 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 340px;
    flex: 0 0 100%;
    min-width: 0;
    transition: border-color var(--duration-slow), box-shadow var(--duration-slow), transform var(--duration-slow);
  }

  .project-card:hover,
  .project-card:active {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .project-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-on-light);
    background: var(--color-accent-glow);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-pill);
    width: fit-content;
    margin-bottom: 1rem;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 0.75rem;
  }

  .project-title a {
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .project-title a:hover {
    color: var(--color-accent);
  }

  .project-title svg {
    opacity: 0.4;
    flex-shrink: 0;
  }

  .project-description {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    flex: 1;
    overflow-wrap: break-word;
  }

  .project-highlight {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-dim);

    a {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover {
        color: var(--color-accent);
      }
    }
    background: var(--color-accent-glow);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-md);
    border-left: 3px solid var(--color-accent);
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg-light);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .projects {
      padding-inline: var(--space-section-inline);
    }

    .project-card {
      padding: var(--space-lg) 1.5rem;
      min-height: auto;
    }

    .project-title {
      font-size: 1.25rem;
    }

    .project-description {
      font-size: 0.9rem;
    }

    .project-tag {
      font-size: 0.75rem;
    }

    .tech-tag {
      font-size: 0.75rem;
    }

    .project-highlight {
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  import { initCarousel } from '../scripts/carousel';
  initCarousel({
    trackId: 'projects-track',
    dotsSelector: '#projects-dots .carousel-dot',
    gallerySelector: '#projects-gallery .gallery-item',
    prevBtnId: 'projects-prev',
    nextBtnId: 'projects-next',
    carouselId: 'projects-carousel',
  });
</script>
