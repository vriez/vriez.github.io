---
const experiences = [
  {
    role: 'Head of Digital Innovation',
    company: 'Crisis Management Center',
    location: 'Vienna, Austria',
    period: '2025 - present',
    description: 'Directing R&D for Austria\'s crisis and disaster management center. Created Atlas, an AI decision-support platform presented at the Austrian Parliament.',
  },
  {
    role: 'Head of Innovation & R&D',
    company: 'Restaurant Chain',
    location: 'Brasilia, Brazil',
    period: '2023 - 2024',
    description: 'Stood up a 10-engineer R&D team from scratch. Shipped demand forecasting, inventory automation, and RAG-based internal tools to 50+ restaurant locations.',
  },
  {
    role: 'Senior Engineer & Tech Lead',
    company: 'PropTech Company',
    location: 'Sydney, Australia',
    period: '2019 - 2022',
    description: 'Promoted to Tech Lead after shipping the fraud-detection pipeline. Ran engineering teams in Australia, Europe, and Asia. Designed OCR and geoprocessing systems using Reinforcement Learning.',
  },
  {
    role: 'Data Engineer',
    company: 'Infrastructure Analytics',
    location: 'Melbourne, Australia',
    period: '2018 - 2019',
    description: 'Developed computer vision for road infrastructure monitoring — detecting pavement damage from vehicle-mounted cameras using Azure Custom Vision.',
  },
  {
    role: 'Full Stack Engineer',
    company: 'Enterprise Software Company',
    location: 'Vienna, Austria',
    period: '2016 - 2018',
    description: 'Modernized the enterprise application suite — zero-downtime database migrations, new authentication layer, and frontend overhaul.',
  },
  {
    role: 'DevOps Engineer & Co-Founder',
    company: 'Risk Analytics Startup',
    location: 'São Paulo, Brazil',
    period: '2015 - 2019',
    description: 'Co-founded a platform for market and environmental risk scoring. Owned the data pipeline — ingestion, geospatial analysis, and the scoring models clients used for site selection.',
  },
];
---

<section class="experience" id="experience">
  <div class="experience-inner">
    <div class="container">
      <div class="experience-header fade-in">
        <p class="section-label section-label--light">Career</p>
        <h2 class="section-title section-title--light">Experience</h2>
        <p class="section-subtitle section-subtitle--light">
          From co-founding a startup in São Paulo to directing R&D in Vienna.
        </p>
      </div>
      <div class="timeline">
        {experiences.map((exp, i) => (
          <div class="timeline-item fade-in" style={`transition-delay: ${i * 0.08}s`}>
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-meta">
                <span class="timeline-period">{exp.period}</span>
                <span class="timeline-location">{exp.location}</span>
              </div>
              <h3 class="timeline-role">{exp.role}</h3>
              <p class="timeline-company">{exp.company}</p>
              <p class="timeline-description">{exp.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .experience {
    background: var(--color-bg-dark);
  }

  .experience-inner {
    padding-inline: 2rem;
    padding-bottom: 4rem;
  }

  .experience-header {
    margin-bottom: 3rem;
  }

  .section-label--light {
    color: var(--color-accent);
  }

  .section-title--light {
    color: var(--color-text-light);
  }

  .section-subtitle--light {
    color: var(--color-text-muted-light);
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 0;
    width: 1px;
    background: var(--color-border-dark);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -2rem;
    top: 8px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-bg-dark);
    border: 2px solid var(--color-accent);
    z-index: 1;
  }

  .timeline-item:first-child .timeline-dot {
    background: var(--color-accent);
  }

  .timeline-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .timeline-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .timeline-location {
    font-size: 0.8rem;
    color: var(--color-text-muted-light);
  }

  .timeline-role {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-bottom: 0.15rem;
  }

  .timeline-company {
    font-size: 0.9rem;
    color: var(--color-text-muted-light);
    margin-bottom: 0.5rem;
  }

  .timeline-description {
    font-size: 0.85rem;
    color: var(--color-text-muted-light);
    line-height: 1.7;
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .experience-inner {
      padding-inline: 1.25rem;
    }

    .timeline {
      padding-left: 1.5rem;
    }

    .timeline-dot {
      left: -1.5rem;
    }

    .timeline-meta {
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>
