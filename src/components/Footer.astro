---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="footer-logo">VR<span class="footer-dot">.</span></span>
        <span class="footer-copy">{year} Vitor Reis</span>
      </div>
      <div class="footer-right">
        <span class="footer-text">Vienna, Austria</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-dark);
    border-top: 1px solid var(--color-border-dark);
    padding: 2rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-logo {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text-light);
  }

  .footer-dot {
    color: var(--color-accent);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted-light);
  }

  .footer-text {
    font-size: 0.8rem;
    color: var(--color-text-muted-light);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
