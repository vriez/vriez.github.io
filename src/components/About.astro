<section class="about" id="about">
  <div class="container">
    <div class="about-layout fade-in">
      <div class="about-content">
        <p class="section-label">About me</p>
        <h2 class="section-title">Where research meets<br />a shipping deadline.</h2>
        <div class="about-text">
          <p>
            I've spent most of my career moving between academia and industry —
            running R&D for Brazil's largest restaurant chain, designing knowledge
            graphs for a biotech MSc, and now directing crisis-management AI in Vienna.
          </p>
          <p>
            I'm most useful where these worlds overlap — the kind of work where you
            need someone who can read the paper and write the deployment config.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding-inline: var(--space-section-inline);
    padding-bottom: var(--space-2xl);
    background: var(--color-bg-dark);
  }

  .about-layout {
    max-width: 640px;
  }

  .about .section-label,
  .about .section-title {
    color: var(--color-text-light);
  }

  .about .section-label {
    color: var(--color-accent-on-dark);
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-text p {
    font-size: 1rem;
    color: var(--color-text-muted-light);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .about {
      padding-inline: var(--space-section-inline);
    }
  }
</style>
