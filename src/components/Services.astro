---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'AI Strategy & Architecture',
    description: 'End-to-end AI system design from proof-of-concept to production. RAG systems, LLM integration, computer vision, and MLOps infrastructure that scales.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
    title: 'Digital Transformation',
    description: 'Transitioning traditional operations to AI-driven workflows. Led rollout across 50+ restaurant locations including demand forecasting, inventory automation, and internal tooling.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    title: 'R&D & Innovation Leadership',
    description: 'Building and leading cross-functional R&D teams. Autonomous drone systems, knowledge graphs, and OCR — from paper to deployed system.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>`,
    title: 'Technical Due Diligence',
    description: 'Architecture reviews, technology assessments, and technical roadmapping. Evaluating systems across AI, data pipelines, cloud infrastructure, and security.',
  },
];
---

<section class="services" id="services">
  <div class="container">
    <div class="services-header fade-in">
      <p class="section-label">What I do</p>
      <h2 class="section-title">Services</h2>
      <p class="section-subtitle">
        Helping organizations design, build, and deploy AI systems.
      </p>
    </div>
    <div class="services-grid">
      {services.map((service, i) => (
        <div class="service-card fade-in" style={`transition-delay: ${i * 0.1}s`}>
          <div class="service-icon" set:html={service.icon} />
          <h3 class="service-title">{service.title}</h3>
          <p class="service-description">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 5rem 2rem;
    background: var(--color-bg-light);
  }

  .services-header {
    margin-bottom: 2.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    border-left: 2px solid var(--color-border);
    padding: 0.5rem 0 0.5rem 1.75rem;
    transition: border-color 0.2s;
  }

  .service-card:hover {
    border-color: var(--color-accent);
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .service-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text-dark);
  }

  .service-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
