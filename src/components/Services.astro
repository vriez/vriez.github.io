---
const services = [
  {
    title: 'AI Strategy & Architecture',
    description: 'Designing AI systems that ship — RAG pipelines, LLM integration, computer vision, and the MLOps infrastructure behind them. I\'ve taken projects from whiteboard sketch to serving real traffic.',
  },
  {
    title: 'AI for Operations',
    description: 'Replacing inefficient processes with AI that operations teams actually use — from ML models to autonomous agentic workflows with built-in human oversight. AI agents and predictive ML models integrated into the ERPs, automating operational workflows across multiple locations.',
  },
  {
    title: 'R&D & Innovation Leadership',
    description: 'Assembling and leading R&D teams that ship — turning research into production software across deep tech domains like autonomous systems, computer vision, and knowledge engineering.',
  },
];
---

<section class="services" id="services">
  <div class="container">
    <div class="services-header fade-in">
      <p class="section-label">What I do</p>
      <h2 class="section-title">Services</h2>
      <p class="section-subtitle">
        I help organizations get AI into production and keep it running.
      </p>
    </div>
    <div class="services-list">
      {services.map((service, i) => (
        <div class="service-item fade-in" style={`transition-delay: ${i * 0.1}s`}>
          <span class="service-number">{String(i + 1).padStart(2, '0')}</span>
          <div class="service-content">
            <h3 class="service-title">{service.title}</h3>
            <p class="service-description">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding-inline: 2rem;
    padding-bottom: 4rem;
    background: var(--color-bg-light);
  }

  .services-header {
    margin-bottom: 3rem;
  }

  .services-list {
    display: flex;
    flex-direction: column;
  }

  .service-item {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .service-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .service-number {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
    flex-shrink: 0;
    width: 3rem;
    padding-top: 0.15rem;
  }

  .service-content {
    flex: 1;
    min-width: 0;
  }

  .service-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text-dark);
  }

  .service-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 640px;
    overflow-wrap: break-word;
  }

  @media (max-width: 768px) {
    .services {
      padding-inline: 1.25rem;
    }

    .service-item {
      gap: 1.25rem;
      padding: 1.5rem 0;
    }

    .service-number {
      font-size: 1.5rem;
      width: 2.25rem;
    }
  }
</style>
