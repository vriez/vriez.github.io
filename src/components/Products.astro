    description: 'High-performance web crawler. Handles static pages, JavaScript-rendered content, and authenticated sessions through an agentic workflow — fast, reliable, and ready for production scraping and indexing pipelines.',
    license: 'Commercial license',
    status: 'Available',
    href: '/products/web-crawler',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><line x1="3" y1="7" x2="21" y2="7"/><circle cx="17" cy="5" r="0.5" fill="currentColor"/><circle cx="15" cy="5" r="0.5" fill="currentColor"/><circle cx="19" cy="5" r="0.5" fill="currentColor"/><path d="M14 11l-3 7l-1-4l-4-1z"/><path d="M14 11l-4 2"/></svg>`,
