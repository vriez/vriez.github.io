---
const products = [
  {
    name: 'Krabby',
    description: 'High-performance web crawler. Handles static pages, JavaScript-rendered content, and authenticated sessions through an agentic workflow — fast, reliable, and ready for production scraping and indexing pipelines.',
    license: 'Commercial license',
    status: 'Available',
    href: '/products/web-crawler',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><line x1="3" y1="7" x2="21" y2="7"/><circle cx="17" cy="5" r="0.5" fill="currentColor"/><circle cx="15" cy="5" r="0.5" fill="currentColor"/><circle cx="19" cy="5" r="0.5" fill="currentColor"/><path d="M14 11l-3 7l-1-4l-4-1z"/><path d="M14 11l-4 2"/></svg>`,
  },
  {
    name: 'Ontologyzer',
    description: 'Enterprise platform that turns any data into a semantic ontology. Define your objects, relationships, and rules once — the platform extracts, maps, and unifies everything into a single queryable knowledge layer. AI-ready out of the box.',
    license: 'Commercial license',
    status: 'Available',
    href: '/products/ontologyzer',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2.5 9.5h19"/><path d="M2.5 14.5h19"/><ellipse cx="12" cy="12" rx="4" ry="10"/><circle cx="6" cy="6" r="1.5" fill="currentColor" stroke="none"/><circle cx="18" cy="8" r="1.5" fill="currentColor" stroke="none"/><circle cx="5" cy="14" r="1.5" fill="currentColor" stroke="none"/><circle cx="15" cy="5" r="1.5" fill="currentColor" stroke="none"/><circle cx="19" cy="14" r="1.5" fill="currentColor" stroke="none"/><circle cx="12" cy="19" r="1.5" fill="currentColor" stroke="none"/><circle cx="8" cy="10" r="1.5" fill="currentColor" stroke="none"/><line x1="6" y1="6" x2="15" y2="5"/><line x1="6" y1="6" x2="8" y2="10"/><line x1="8" y1="10" x2="5" y2="14"/><line x1="8" y1="10" x2="18" y2="8"/><line x1="18" y1="8" x2="19" y2="14"/><line x1="5" y1="14" x2="12" y2="19"/><line x1="19" y1="14" x2="12" y2="19"/></svg>`,
  },
  {
    name: 'Tesselage',
    description: 'Real-time geospatial intelligence on a 3D globe. Fuses live aviation, maritime, satellite, weather, and logistics data into one unified view — with a local AI you can query in natural language. Offline-first, zero data leaves your machine.',
    license: 'Commercial license',
    status: 'In Development',
    href: '/products/tesselage',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5L12 2z"/><path d="M2 12l10 5 10-5"/><path d="M2 17l10 5 10-5"/></svg>`,
  },
  {
    name: 'Marketeer',
    description: 'End-to-end marketing platform. Orchestrates campaigns, content generation, audience segmentation, analytics, and multi-channel delivery from a single control plane — replacing the patchwork of point tools with one coherent system.',
    license: 'Commercial license',
    status: 'In Development',
    href: '/products/marketeer',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 9V5"/><path d="M12 19v-4"/><path d="M9 12H5"/><path d="M19 12h-4"/><circle cx="12" cy="4" r="1.5" fill="currentColor" stroke="none"/><circle cx="12" cy="20" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none"/><circle cx="20" cy="12" r="1.5" fill="currentColor" stroke="none"/><path d="M8 5.5a9 9 0 0 0-2.5 2.5"/><path d="M5.5 16a9 9 0 0 0 2.5 2.5"/><path d="M16 18.5a9 9 0 0 0 2.5-2.5"/><path d="M18.5 8a9 9 0 0 0-2.5-2.5"/><path d="M9.5 7.5l-1-2"/><path d="M15.5 18.5l-1-2"/><path d="M7.5 14.5l-2 1"/><path d="M18.5 9.5l-2 1"/></svg>`,
  },
];
---

<section class="products" id="products">
  <div class="container">
    <div class="products-header fade-in">
      <p class="section-label">Products & Licensing</p>
      <h2 class="section-title">Ready-to-deploy solutions</h2>
      <p class="section-subtitle">
        Products extracted from client and research work,
        available for licensing or custom deployment.
      </p>
    </div>

    <div class="carousel-layout fade-in">
      <!-- Gallery nav -->
      <nav class="gallery" id="products-gallery" aria-label="Product navigation">
        {products.map((product, i) => (
          <button
            class={`gallery-item ${i === 0 ? 'active' : ''}`}
            data-index={i}
          >
            <span class="gallery-icon" set:html={product.icon} />
            <span class="gallery-text">
              <span class="gallery-name">{product.name}</span>
              <span class={`gallery-status ${product.status === 'Available' ? 'available' : 'soon'}`}>
                {product.status}
              </span>
            </span>
            <span class="gallery-indicator" />
          </button>
        ))}
      </nav>

      <!-- Carousel -->
      <div class="carousel-main">
        <div class="carousel" id="products-carousel" tabindex="0" role="region" aria-label="Product carousel">
          <div class="carousel-track" id="products-track" aria-live="polite">
            {products.map((product) => (
              <a href={product.href} class="product-card-link">
                <div class="product-card">
                  <div class="product-header">
                    <h3 class="product-name">{product.name}</h3>
                    <span class={`product-status ${product.status === 'Available' ? 'available' : 'soon'}`}>
                      {product.status}
                    </span>
                  </div>
                  <p class="product-description">{product.description}</p>
                  <div class="product-footer">
                    <span class="product-license">{product.license}</span>
                    <span class="product-cta">View {product.name} &rarr;</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="carousel-controls">
          <div class="carousel-dots" id="products-dots">
            {products.map((_, i) => (
              <button
                class={`carousel-dot ${i === 0 ? 'active' : ''}`}
                data-index={i}
                aria-label={`Go to product ${i + 1}`}
              />
            ))}
          </div>
          <div class="carousel-arrows">
            <button class="carousel-arrow prev" id="products-prev" aria-label="Previous product">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="carousel-arrow next" id="products-next" aria-label="Next product">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initCarousel } from '../scripts/carousel';
  initCarousel({
    trackId: 'products-track',
    dotsSelector: '#products-dots .carousel-dot',
    gallerySelector: '#products-gallery .gallery-item',
    prevBtnId: 'products-prev',
    nextBtnId: 'products-next',
    carouselId: 'products-carousel',
  });
</script>

<style>
  .products {
    padding-inline: var(--space-section-inline);
    padding-bottom: var(--space-2xl);
    background: var(--color-bg-warm);
  }

  .products-header {
    margin-bottom: var(--space-xl);
  }

  .product-card-link {
    flex: 0 0 100%;
    min-width: 0;
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 0 0.25rem;
  }

  .product-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl) 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 340px;
    transition: border-color var(--duration-slow), box-shadow var(--duration-slow), transform var(--duration-slow);
  }

  .product-card-link:hover .product-card,
  .product-card-link:active .product-card {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .product-card-link:hover .product-cta,
  .product-card-link:active .product-cta {
    color: var(--color-accent-hover);
    gap: 0.6rem;
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .product-name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-dark);
  }

  .product-status {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    white-space: nowrap;
    margin-top: 0.3rem;
  }

  .product-status.available {
    color: var(--color-accent-on-light);
    background: rgba(var(--color-accent-rgb), 0.1);
  }

  .product-status.soon {
    color: var(--color-text-muted);
    background: var(--color-bg-light);
  }

  .product-description {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    flex: 1;
    overflow-wrap: break-word;
  }

  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .product-license {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .product-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: color var(--duration-base), gap var(--duration-slow);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .products {
      padding-inline: var(--space-section-inline);
    }

    .product-card {
      padding: var(--space-lg) 1.5rem;
      min-height: auto;
    }

    .product-name {
      font-size: 1.25rem;
    }

    .product-description {
      font-size: 0.9rem;
    }

    .product-status {
      font-size: 0.75rem;
    }

    .product-license,
    .product-cta {
      font-size: var(--text-sm);
    }
  }
</style>
