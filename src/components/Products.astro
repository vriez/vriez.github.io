---
const products = [
  {
    name: 'Web Crawler',
    description: 'High-performance web crawler built in Rust. Does what Firecrawl does — except it actually works. Fast, reliable, and ready for production scraping and indexing pipelines.',
    license: 'Commercial license',
    status: 'Available',
  },
  {
    name: 'Ontologyzer',
    description: 'Automated ontology extraction and structuring engine. Similar to LangExtract, but one that actually works. Extracts entities, relations, and taxonomies from unstructured text.',
    license: 'Commercial license',
    status: 'Available',
  },
  {
    name: 'Tesselage',
    description: 'C⁴SIR platform for businesses. Comprehensive command, control, communications, computers, surveillance, intelligence, and reconnaissance solution tailored for enterprise operations.',
    license: 'Commercial license',
    status: 'In Development',
  },
];
---

<section class="products" id="products">
  <div class="container">
    <div class="products-header fade-in">
      <p class="section-label">Products & Licensing</p>
      <h2 class="section-title">Ready-to-deploy solutions</h2>
      <p class="section-subtitle">
        Battle-tested products built from real-world projects,
        available for licensing or custom deployment.
      </p>
    </div>
    <div class="products-grid">
      {products.map((product, i) => (
        <div class="product-card fade-in" style={`transition-delay: ${i * 0.1}s`}>
          <div class="product-header">
            <h3 class="product-name">{product.name}</h3>
            <span class={`product-status ${product.status === 'Available' ? 'available' : 'soon'}`}>
              {product.status}
            </span>
          </div>
          <p class="product-description">{product.description}</p>
          <div class="product-footer">
            <span class="product-license">{product.license}</span>
            <a href="#contact" class="product-cta">Inquire</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .products {
    padding-inline: 2rem;
    padding-bottom: 4rem;
    background: var(--color-bg-warm);
  }

  .products-header {
    margin-bottom: 3rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .product-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-height: 400px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .product-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .product-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-dark);
  }

  .product-status {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .product-status.available {
    color: var(--color-accent);
    background: rgba(var(--color-accent-rgb), 0.1);
  }

  .product-status.soon {
    color: var(--color-text-muted);
    background: var(--color-bg-light);
  }

  .product-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
  }

  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .product-license {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .product-cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: color 0.2s;
  }

  .product-cta:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
