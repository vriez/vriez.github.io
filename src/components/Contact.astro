---
interface Props {
  subject?: string;
}

const { subject = 'General Inquiry' } = Astro.props;
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact-layout fade-in">
      <div class="contact-text">
        <p class="section-label">Get in touch</p>
        <h2 class="section-title">Let's work<br />together.</h2>
        <p class="contact-description">
          Whether you need an AI system designed, a technical review before
          a big decision, or a research collaborator &mdash; I'd like to hear from you.
        </p>
      </div>
       <form class="contact-form" action="https://formsubmit.co/vitor.ereis@proton.me" method="POST" enctype="multipart/form-data">
         <input type="text" name="_honey" style="display:none">
         <input type="hidden" name="_captcha" value="false">
         <input type="hidden" name="_next" value="https://vitor-reis.github.io/#contact">
         <div class="form-group">
          <label for="contact-name" class="sr-only">Name</label>
          <input type="text" id="contact-name" name="name" placeholder="Name" required />
        </div>
        <div class="form-group">
          <label for="contact-subject" class="sr-only">Subject</label>
          <input type="text" id="contact-subject" name="subject" placeholder="Subject" value={subject} />
        </div>
        <div class="form-group">
          <label for="contact-email" class="sr-only">Email</label>
          <input type="email" id="contact-email" name="email" placeholder="Email" required />
        </div>
        <div class="form-group">
          <label class="sr-only">Message</label>
          <input type="hidden" id="contact-message-hidden" name="message" />
          <div class="editor-wrap">
            <div class="editor-toolbar">
              <button type="button" class="toolbar-btn" data-command="bold" title="Bold">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M15.6 10.79c.97-.67 1.65-1.77 1.65-2.79 0-2.26-1.75-4-4-4H7v14h7.04c2.09 0 3.71-1.7 3.71-3.79 0-1.52-.86-2.82-2.15-3.42zM10 6.5h3c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-3v-3zm3.5 9H10v-3h3.5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5z"/></svg>
              </button>
              <button type="button" class="toolbar-btn" data-command="italic" title="Italic">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M10 4v3h2.21l-3.42 8H6v3h8v-3h-2.21l3.42-8H18V4z"/></svg>
              </button>
              <button type="button" class="toolbar-btn" data-command="underline" title="Underline">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17c3.31 0 6-2.69 6-6V3h-2.5v8c0 1.93-1.57 3.5-3.5 3.5S8.5 12.93 8.5 11V3H6v8c0 3.31 2.69 6 6 6zm-7 2v2h14v-2H5z"/></svg>
              </button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-command="insertUnorderedList" title="Bullet list">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M4 10.5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5-.67-1.5-1.5-1.5zm0-6c-.83 0-1.5.67-1.5 1.5S3.17 7.5 4 7.5 5.5 6.83 5.5 6 4.83 4.5 4 4.5zm0 12c-.83 0-1.5.68-1.5 1.5s.68 1.5 1.5 1.5 1.5-.68 1.5-1.5-.67-1.5-1.5-1.5zM7 19h14v-2H7v2zm0-6h14v-2H7v2zm0-8v2h14V5H7z"/></svg>
              </button>
              <button type="button" class="toolbar-btn" data-command="insertOrderedList" title="Numbered list">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-6v2h14V5H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z"/></svg>
              </button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-command="removeFormat" title="Clear formatting">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3.27 5L2 6.27l6.97 6.97L6.5 19h3l1.57-3.66L16.73 21 18 19.73 3.27 5zM6 5v.18L8.82 8h2.4l-.72 1.68 2.1 2.1L14.21 8H20V5H6z"/></svg>
              </button>
            </div>
            <div
              class="editor-content"
              id="contact-message"
              contenteditable="true"
              role="textbox"
              aria-multiline="true"
              aria-label="Message"
              data-placeholder="Message"
            ></div>
          </div>
        </div>
        <div class="form-group">
          <label for="contact-attachment" class="file-upload-label">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
            <span class="file-upload-text">Attach a file <span class="file-hint">(max 10 MB)</span></span>
            <span class="file-name" id="file-name-display"></span>
          </label>
          <input type="file" id="contact-attachment" name="attachment" class="file-input" />
        </div>
        <button type="submit" class="btn-submit">
          Send message
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
      <div class="social-links">
        <a href="https://github.com/vriez" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/victor-r-9892a449/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-inline: 2rem;
    padding-bottom: 4rem;
    background: var(--color-bg-light);
  }

  .contact-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .contact-text {
    display: flex;
    flex-direction: column;
    max-width: 600px;
  }

  .contact-description {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 480px;
  }

   .contact-form {
     display: flex;
     flex-direction: column;
     gap: 0.75rem;
     width: 100%;
     max-width: 480px;
     margin-left: auto;
     margin-right: 20%;
     margin-top: -2rem; /* Move form up */
   }

  .contact-form input[type="text"],
  .contact-form input[type="email"] {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-dark);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }

  .contact-form input[type="text"]:focus,
  .contact-form input[type="email"]:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb), 0.1);
  }

  /* Rich text editor */
  .editor-wrap {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-card);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .editor-wrap:focus-within {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb), 0.1);
  }

  .editor-toolbar {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 0.35rem 0.5rem;
    background: var(--color-bg-light);
    border-bottom: 1px solid var(--color-border);
  }

  .toolbar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .toolbar-btn:hover {
    background: var(--color-border);
    color: var(--color-text-dark);
  }

  .toolbar-btn.active {
    background: var(--color-accent);
    color: var(--color-text-light);
  }

  .toolbar-sep {
    width: 1px;
    height: 18px;
    background: var(--color-border);
    margin: 0 4px;
  }

  .editor-content {
    min-height: 180px;
    max-height: 400px;
    overflow-y: auto;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-dark);
    line-height: 1.6;
    outline: none;
  }

  .editor-content:empty::before {
    content: attr(data-placeholder);
    color: var(--color-text-muted);
    opacity: 0.6;
    pointer-events: none;
  }

  .editor-content ul,
  .editor-content ol {
    padding-left: 1.5rem;
    margin: 0.25rem 0;
  }

  /* File upload */
  .file-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .file-upload-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px dashed var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .file-upload-label:hover {
    border-color: var(--color-accent);
    color: var(--color-text-dark);
  }

  .file-hint {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .file-name {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
  }

   .btn-submit {
     display: inline-flex;
     align-items: center;
     justify-content: center;
     gap: 0.5rem;
     padding: 0.75rem 1.75rem;
     font-family: var(--font-body);
     font-size: 0.9rem;
     font-weight: 600;
     color: var(--color-text-light);
     background: var(--color-accent);
     border: none;
     border-radius: 6px;
     cursor: pointer;
     transition: background 0.2s, transform 0.2s;
     align-self: flex-end;
   }

  .btn-submit:hover:not(:disabled) {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .btn-submit:active:not(:disabled) {
    transform: translateY(0) scale(0.97);
  }

  .btn-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .editor-wrap.editor-error {
    border-color: var(--color-error);
    box-shadow: 0 0 0 3px var(--color-error-glow);
  }

  .file-error {
    color: var(--color-error) !important;
  }

  .social-links {
    display: flex;
    gap: 0.5rem;
  }

  @media (max-width: 1024px) {
    .contact-form {
      margin-right: 0;
    }
  }

  @media (max-width: 768px) {
    .contact {
      padding-inline: 1.25rem;
    }

    .contact-form {
      margin-left: 0;
      margin-right: 0;
      margin-top: 0;
    }

    /* 16px prevents iOS Safari auto-zoom on focus */
    .contact-form input[type="text"],
    .contact-form input[type="email"] {
      font-size: 1rem;
    }

    .editor-content {
      font-size: 1rem;
      min-height: 140px;
    }
  }

  .social-links a {
    color: var(--color-text-muted);
    transition: color 0.2s, transform 0.2s;
    padding: 0.75rem;
  }

  .social-links a:hover {
    color: var(--color-accent);
    transform: translateY(-2px);
  }

</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const subjectInput = document.getElementById('contact-subject') as HTMLInputElement | null;

    // Check URL query parameter for cross-page subject
    if (subjectInput) {
      const params = new URLSearchParams(window.location.search);
      const urlSubject = params.get('subject');
      if (urlSubject) {
        subjectInput.value = urlSubject;
      }
    }

    // Handle same-page contact links with data-subject
    const contactLinks = document.querySelectorAll('.contact-link');
    if (contactLinks.length && subjectInput) {
      contactLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const subject = link.getAttribute('data-subject');
          if (subject) {
            subjectInput.value = subject;
            const contactSection = document.getElementById('contact');
            if (contactSection) {
              contactSection.scrollIntoView({ behavior: 'smooth' });
            }
          }
        });
      });
    }

    // Rich text editor toolbar
    const editor = document.getElementById('contact-message') as HTMLDivElement | null;
    const hiddenInput = document.getElementById('contact-message-hidden') as HTMLInputElement | null;
    const toolbarBtns = document.querySelectorAll('.toolbar-btn');

    toolbarBtns.forEach(btn => {
      btn.addEventListener('mousedown', (e) => {
        e.preventDefault(); // prevent focus loss from editor
        const command = (btn as HTMLElement).dataset.command;
        if (command) {
          document.execCommand(command, false);
          updateToolbarState();
        }
      });
    });

    // Update active state of toolbar buttons
    function updateToolbarState() {
      toolbarBtns.forEach(btn => {
        const command = (btn as HTMLElement).dataset.command;
        if (command && command !== 'removeFormat') {
          btn.classList.toggle('active', document.queryCommandState(command));
        }
      });
    }

    if (editor) {
      editor.addEventListener('keyup', updateToolbarState);
      editor.addEventListener('mouseup', updateToolbarState);

      // Sync editor content to hidden input on form submit
      const form = editor.closest('form');
      const submitBtn = form?.querySelector('.btn-submit') as HTMLButtonElement | null;
      if (form && hiddenInput && submitBtn) {
        form.addEventListener('submit', (e) => {
          const content = editor.innerHTML.trim();
          if (!content || content === '<br>') {
            e.preventDefault();
            editor.focus();
            editor.closest('.editor-wrap')?.classList.add('editor-error');
            return;
          }
          hiddenInput.value = content;

          // File size check (10 MB)
          const fInput = document.getElementById('contact-attachment') as HTMLInputElement | null;
          if (fInput?.files?.length) {
            const file = fInput.files[0];
            if (file.size > 10 * 1024 * 1024) {
              e.preventDefault();
              fInput.value = '';
              const nameEl = document.getElementById('file-name-display');
              if (nameEl) {
                nameEl.textContent = 'File too large (max 10 MB)';
                nameEl.classList.add('file-error');
              }
              return;
            }
          }

          // Prevent double submission
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending\u2026';
        });
      }

      // Clear error state on input
      editor.addEventListener('input', () => {
        editor.closest('.editor-wrap')?.classList.remove('editor-error');
      });
    }

    // File upload display
    const fileInput = document.getElementById('contact-attachment') as HTMLInputElement | null;
    const fileNameDisplay = document.getElementById('file-name-display');

    if (fileInput && fileNameDisplay) {
      fileInput.addEventListener('change', () => {
        fileNameDisplay.classList.remove('file-error');
        if (fileInput.files && fileInput.files.length > 0) {
          const file = fileInput.files[0];
          if (file.size > 10 * 1024 * 1024) {
            fileInput.value = '';
            fileNameDisplay.textContent = 'File too large (max 10 MB)';
            fileNameDisplay.classList.add('file-error');
          } else {
            fileNameDisplay.textContent = file.name;
          }
        } else {
          fileNameDisplay.textContent = '';
        }
      });
    }
  });
</script>
