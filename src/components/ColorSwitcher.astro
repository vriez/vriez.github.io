<div class="color-switcher">
  <button class="swatch" data-color="green" style="--sw: #10b981;" title="Green" aria-label="Green accent"></button>
  <button class="swatch" data-color="blue" style="--sw: #3b82f6;" title="Blue" aria-label="Blue accent"></button>
  <button class="swatch" data-color="purple" style="--sw: #8a05be;" title="Purple" aria-label="Purple accent"></button>
  <button class="swatch" data-color="yellow" style="--sw: #eab308;" title="Yellow" aria-label="Yellow accent"></button>
  <button class="swatch" data-color="orange" style="--sw: #f97316;" title="Orange" aria-label="Orange accent"></button>
</div>

<script>
  const themes: Record<string, { accent: string; hover: string; dim: string; rgb: string; onLight: string; onDark: string }> = {
    green:  { accent: '#10b981', hover: '#059669', dim: '#064e3b', rgb: '16, 185, 129', onLight: '#0e7f5a', onDark: '#34d399' },
    blue:   { accent: '#3b82f6', hover: '#2563eb', dim: '#1e3a5f', rgb: '59, 130, 246', onLight: '#2b6cb0', onDark: '#6ba3f5' },
    purple: { accent: '#8a05be', hover: '#6b00a8', dim: '#3b0064', rgb: '138, 5, 190', onLight: '#8b24b2', onDark: '#b84de0' },
    yellow: { accent: '#eab308', hover: '#ca8a04', dim: '#713f12', rgb: '234, 179, 8', onLight: '#866610', onDark: '#f0c23a' },
    orange: { accent: '#f97316', hover: '#ea580c', dim: '#7c2d12', rgb: '249, 115, 22', onLight: '#c05709', onDark: '#fb923c' },
  };

  function applyTheme(color: string) {
    const t = themes[color];
    if (!t) return;
    const r = document.documentElement.style;
    r.setProperty('--color-accent', t.accent);
    r.setProperty('--color-accent-hover', t.hover);
    r.setProperty('--color-accent-dim', t.dim);
    r.setProperty('--color-accent-rgb', t.rgb);
    r.setProperty('--color-accent-glow', `rgba(${t.rgb}, 0.15)`);
    r.setProperty('--color-accent-on-light', t.onLight);
    r.setProperty('--color-accent-on-dark', t.onDark);
    document.querySelectorAll('.swatch').forEach((s) => {
      const isActive = (s as HTMLElement).dataset.color === color;
      s.classList.toggle('active', isActive);
      s.setAttribute('aria-pressed', String(isActive));
    });
    localStorage.setItem('accent-color', color);
  }

  document.querySelectorAll('.swatch').forEach((btn) => {
    btn.addEventListener('click', () => applyTheme((btn as HTMLElement).dataset.color!));
  });

  const savedColor = localStorage.getItem('accent-color');
  if (savedColor && themes[savedColor]) applyTheme(savedColor);
  else applyTheme('orange');
</script>

<style>
  .color-switcher {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: var(--z-overlay);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(12px);
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .swatch {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: var(--sw);
    cursor: pointer;
    transition: transform var(--duration-base), border-color var(--duration-base), box-shadow var(--duration-base);
    padding: 0;
    /* 44px touch target via padding, keeps visual size at 24px */
    position: relative;
  }

  .swatch::after {
    content: '';
    position: absolute;
    inset: -10px;
  }

  .swatch:hover {
    transform: scale(1.2);
  }

  .swatch.active {
    border-color: #fff;
    box-shadow: 0 0 8px var(--sw);
  }

  @media (max-width: 768px) {
    .color-switcher {
      bottom: 1rem;
      right: 1rem;
      gap: 0.35rem;
      padding: 0.4rem 0.6rem;
    }

    .swatch {
      width: 20px;
      height: 20px;
    }
  }
</style>
