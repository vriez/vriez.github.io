---
const partnerTypes = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Strategic Partnerships',
    description: 'Long-term collaborations where both sides bring something to the table. I\'ve partnered with research institutions and technology companies to co-develop AI systems for specific domains — crisis response, food service, infrastructure.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`,
    title: 'White-Label Solutions',
    description: 'License my products — Web Crawler, Ontologyzer, or Tesselage — under your own brand. I handle updates, SLAs, and integration support so your team can focus on the client relationship.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: 'Research Collaboration',
    description: 'Joint research with universities and corporate labs. Open to co-authoring, shared IP arrangements, and funded research proposals.',
  },
];
---

<section class="partnerships" id="partnerships">
  <div class="container">
    <div class="partnerships-header fade-in">
      <p class="section-label">Partnerships</p>
      <h2 class="section-title">Work with me</h2>
      <p class="section-subtitle">
        Open to partnerships that create mutual value &mdash;
        from technology licensing to joint research ventures.
      </p>
    </div>
    <div class="partnerships-grid">
      {partnerTypes.map((type, i) => (
        <div class="partner-card fade-in" style={`transition-delay: ${i * 0.1}s`}>
          <div class="partner-icon" set:html={type.icon} />
          <h3 class="partner-title">{type.title}</h3>
          <p class="partner-description">{type.description}</p>
          <a href="#contact" class="partner-link contact-link" data-subject={`Partnership: ${type.title}`}>
            Start a conversation
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .partnerships {
    padding-inline: 2rem;
    padding-bottom: 4rem;
    background: var(--color-bg-dark);
  }

  .partnerships .section-label {
    color: var(--color-accent-on-dark);
  }

  .partnerships .section-title {
    color: var(--color-text-light);
  }

  .partnerships .section-subtitle {
    color: var(--color-text-muted-light);
  }

  .partnerships-header {
    margin-bottom: 3rem;
  }

  .partnerships-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .partner-card {
    background: var(--color-bg-dark-alt);
    border: 1px solid var(--color-border-dark);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s, transform 0.3s;
  }

  .partner-card:hover,
  .partner-card:active {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .partner-icon {
    color: var(--color-accent);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-accent-rgb), 0.1);
    border-radius: 10px;
  }

  .partner-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-light);
  }

  .partner-description {
    font-size: 0.9rem;
    color: var(--color-text-muted-light);
    line-height: 1.7;
    flex: 1;
  }

  .partner-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent-on-dark);
    transition: gap 0.2s;
  }

  .partner-link:hover {
    gap: 0.7rem;
    color: var(--color-accent-on-dark);
  }

  @media (max-width: 1024px) {
    .partnerships-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .partnerships {
      padding-inline: 1.25rem;
    }

    .partnerships-grid {
      grid-template-columns: 1fr;
    }

    .partner-link {
      padding: 0.5rem 0;
      min-height: 44px;
    }
  }
</style>
