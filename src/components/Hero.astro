---
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-greeting">Solutions Architect &mdash; AI, Data & R&D</p>
      <h1 class="hero-title">
        From research to<br />
        <span class="accent">production AI</span><br />
        systems.
      </h1>
      <p class="hero-description">
        I architect AI systems — from a crisis-response platform presented
        at the Austrian Parliament to demand forecasting running in 50+
        restaurants. A decade of work, five countries.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn-primary">View my work</a>
        <a href="#contact" class="btn-secondary contact-link" data-subject="General Inquiry">Let's talk</a>
      </div>
    </div>
    <div class="hero-photo">
      <div class="photo-wrapper">
        <img src="/me.jpeg" alt="Vitor portrait" loading="eager" decoding="async" style="object-position: center 15%;" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-dark);
    padding-inline: 2rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 5rem;
    max-width: 1100px;
    width: 100%;
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .hero-photo {
    flex-shrink: 0;
    animation: heroFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  .photo-wrapper {
    width: 280px;
    height: 350px;
    border-radius: 12px;
    overflow: hidden;
  }

  .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-greeting {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    animation: heroFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    animation: heroFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .accent {
    color: var(--color-accent);
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--color-text-muted-light);
    max-width: 540px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    animation: heroFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    animation: heroFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-accent);
    color: var(--color-text-light);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 6px;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-text-light);
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    color: var(--color-text-muted-light);
    font-weight: 500;
    font-size: 0.9rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 6px;
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-secondary:hover {
    color: var(--color-text-light);
    border-color: var(--color-text-muted-light);
  }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1.25rem 3rem;
    }

    .hero-inner {
      flex-direction: column-reverse;
      text-align: center;
      gap: 2.5rem;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .btn-primary, .btn-secondary {
      justify-content: center;
    }

    .photo-wrapper {
      width: 200px;
      height: 250px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-greeting,
    .hero-title,
    .hero-description,
    .hero-actions,
    .hero-photo {
      animation: none;
    }
  }
</style>
