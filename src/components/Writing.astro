---
const posts = [
  {
    category: 'Conference',
    title: 'Atlas: Autonomous Decision-Making for Crisis Management',
    description: 'Presented at Language & Intelligence 2025, Austrian Parliament. Human-in-the-loop AI for risk and crisis response.',
    date: '2025',
    href: 'https://www.zfrk.org/neuigkeiten/language-intelligence-2025-zrk-mit-starken-beitraegen-im-parlament-vertreten/',
  },
  {
    category: 'Essay Series',
    title: 'Towards an ImageNet Moment for Handwritten Text Recognition',
    description: 'What it would take to democratize handwritten OCR: the datasets, architectures, and engineering decisions that could bring HTR to every developer\'s toolkit.',
    date: '2019 — ongoing',
  },
];
---

<section class="writing" id="writing">
  <div class="container">
    <div class="writing-header fade-in">
      <p class="section-label">Writing & Publications</p>
      <h2 class="section-title">Ideas & research</h2>
      <p class="section-subtitle">
        Publications, conference presentations, and thoughts on AI, systems, and engineering.
      </p>
    </div>
    <div class="posts-list">
      {posts.map((post, i) => (
        <article class="post-item fade-in" style={`transition-delay: ${i * 0.1}s`}>
          <div class="post-meta">
            <span class="post-category">{post.category}</span>
            <time class="post-date">{post.date}</time>
          </div>
          <h3 class="post-title">
            {post.href ? <a href={post.href}>{post.title}</a> : post.title}
          </h3>
          <p class="post-description">{post.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .writing {
    padding-inline: 2rem;
    padding-bottom: 4rem;
    background: var(--color-bg-warm);
  }

  .writing-header {
    margin-bottom: 3rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-item:has(a):hover .post-title {
    color: var(--color-accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-on-light);
    background: var(--color-accent-glow);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-dark);
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .post-title a {
    color: inherit;
    text-decoration: none;
  }

  .post-title a:hover {
    color: var(--color-accent);
  }

  .post-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 700px;
  }

@media (max-width: 768px) {
    .writing {
      padding-inline: 1.25rem;
    }

    .post-title {
      font-size: 1.1rem;
    }
  }
</style>
