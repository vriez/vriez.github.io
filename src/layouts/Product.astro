---
interface Props {
  name: string;
  description: string;
  status: string;
  license: string;
}

const { name, description, status, license } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Vitor Eulalio Reis" />
    <meta property="og:title" content={name} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="product" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#1a1815" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,600;9..144,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{name} | Vitor Reis</title>
    <script is:inline>
      (function(){
        var t={green:{a:'#10b981',h:'#059669',d:'#064e3b',r:'16,185,129',l:'#0e7f5a',k:'#34d399'},blue:{a:'#3b82f6',h:'#2563eb',d:'#1e3a5f',r:'59,130,246',l:'#2b6cb0',k:'#6ba3f5'},purple:{a:'#8a05be',h:'#6b00a8',d:'#3b0064',r:'138,5,190',l:'#8b24b2',k:'#b84de0'},yellow:{a:'#eab308',h:'#ca8a04',d:'#713f12',r:'234,179,8',l:'#866610',k:'#f0c23a'},orange:{a:'#f97316',h:'#ea580c',d:'#7c2d12',r:'249,115,22',l:'#c05709',k:'#fb923c'}};
        var c=localStorage.getItem('accent-color');
        var v=t[c];if(!v)return;
        var s=document.documentElement.style;
        s.setProperty('--color-accent',v.a);
        s.setProperty('--color-accent-hover',v.h);
        s.setProperty('--color-accent-dim',v.d);
        s.setProperty('--color-accent-rgb',v.r);
        s.setProperty('--color-accent-glow','rgba('+v.r+',0.15)');
        s.setProperty('--color-accent-on-light',v.l);
        s.setProperty('--color-accent-on-dark',v.k);
      })();
    </script>
  </head>
  <body>
    <a href="#post-content" class="skip-link">Skip to main content</a>
    <header class="post-header">
      <div class="post-header-inner">
        <a href="/" class="logo">VR<span class="logo-dot">.</span></a>
        <a href="/#products" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back
        </a>
      </div>
    </header>
    <main id="post-content">
      <article class="post">
        <div class="post-meta-block">
          <div class="product-meta-row">
            <span class="post-category-tag">Product</span>
            <span class={`product-status-badge ${status === 'Available' ? 'available' : 'soon'}`}>
              {status}
            </span>
          </div>
          <h1 class="post-title">{name}</h1>
          <p class="post-description">{description}</p>
          <div class="product-info-row">
            <span class="product-license-label">{license}</span>
            <a href={`/?subject=${encodeURIComponent(name + ' Licensing')}#contact`} class="product-inquire-btn">Inquire about licensing</a>
          </div>
        </div>
        <div class="post-body">
          <slot />
        </div>
      </article>
    </main>
    <footer class="post-footer">
      <div class="post-footer-inner">
        <a href="/#products" class="footer-back">Back to products</a>
        <span class="footer-copy">&copy; {new Date().getFullYear()} Vitor Reis</span>
      </div>
    </footer>
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  html {
    scroll-snap-type: none;
  }

  .post-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: rgba(var(--color-bg-light-rgb), 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 2rem;
  }

  .post-header-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .back-link:hover {
    color: var(--color-text-dark);
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-dark);
  }

  .logo-dot {
    color: var(--color-accent);
  }

  .post-meta-block {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem;
  }

  .product-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .post-category-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-on-light);
    background: var(--color-accent-glow);
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-sm);
  }

  .product-status-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-sm);
  }

  .product-status-badge.available {
    color: var(--color-status-available);
    background: var(--color-status-available-bg);
  }

  .product-status-badge.soon {
    color: var(--color-text-muted);
    background: var(--color-bg-warm);
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text-dark);
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 650px;
  }

  .product-info-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .product-license-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .product-inquire-btn {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-light);
    background: var(--color-accent);
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-md);
    transition: background var(--duration-base);
  }

  .product-inquire-btn:hover {
    background: var(--color-accent-hover);
    color: var(--color-text-light);
  }

  .post-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .post-body h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 3rem 0 1rem;
    line-height: 1.3;
  }

  .post-body h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 2.5rem 0 0.75rem;
  }

  .post-body p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--color-text-dark);
    margin-bottom: 1.25rem;
    overflow-wrap: break-word;
  }

  .post-body ul, .post-body ol {
    margin: 1rem 0 1.5rem 1.5rem;
  }

  .post-body li {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-dark);
    margin-bottom: 0.4rem;
  }

  .post-body strong {
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .post-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body a:hover {
    color: var(--color-accent-hover);
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .post-body blockquote {
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--color-accent-glow);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .post-body blockquote p {
    font-size: 1rem;
    color: var(--color-text-dark);
    margin-bottom: 0;
  }

  .post-body code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875rem;
    background: var(--color-bg-warm);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  /* Feature blocks */
  .feature-block {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-accent);
  }

  .feature-block .feature-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-on-light);
    margin-bottom: 0.4rem;
  }

  .feature-block h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 0 0 0.75rem 0;
  }

  .feature-block p {
    font-size: 0.95rem;
  }

  /* Tech stack pills */
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }

  .tech-pill {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--color-bg-warm);
    color: var(--color-text-dark);
    border: 1px solid var(--color-border);
  }

  .post-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 2rem;
  }

  .post-footer-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-back {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .post-meta-block {
      padding: 3rem 1.25rem 1.5rem;
    }

    .post-body {
      padding: 1.5rem 1.25rem 3rem;
    }

    .product-info-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
