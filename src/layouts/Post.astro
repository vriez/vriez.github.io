---
interface Props {
  title: string;
  description: string;
  date: string;
  readTime: string;
  category: string;
}

const { title, description, date, readTime, category } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Vitor Eulalio Reis" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | Vitor Reis</title>
  </head>
  <body>
    <header class="post-header">
      <div class="post-header-inner">
        <a href="/" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back
        </a>
        <a href="/" class="logo">VR<span class="logo-dot">.</span></a>
      </div>
    </header>
    <article class="post">
      <div class="post-meta-block">
        <span class="post-category-tag">{category}</span>
        <div class="post-meta-info">
          <time>{date}</time>
          <span class="meta-sep">&middot;</span>
          <span>{readTime}</span>
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-author">
          <span class="author-name">Vitor Eulalio Reis</span>
          <span class="author-role">Solutions Architect &mdash; AI, Data & R&D</span>
        </div>
      </div>
      <div class="post-body">
        <slot />
      </div>
    </article>
    <footer class="post-footer">
      <div class="post-footer-inner">
        <a href="/" class="footer-back">Back to home</a>
        <span class="footer-copy">&copy; {new Date().getFullYear()} Vitor Reis</span>
      </div>
    </footer>
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .post-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 2rem;
  }

  .post-header-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .back-link:hover {
    color: var(--color-text-dark);
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-dark);
  }

  .logo-dot {
    color: var(--color-accent);
  }

  /* Post meta */
  .post-meta-block {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem;
  }

  .post-category-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    margin-bottom: 1.25rem;
  }

  .post-meta-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .meta-sep {
    opacity: 0.4;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text-dark);
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 650px;
  }

  .post-author {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .author-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .author-role {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Post body */
  .post-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .post-body h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 3rem 0 1rem;
    line-height: 1.3;
  }

  .post-body h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 2.5rem 0 0.75rem;
  }

  .post-body h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin: 2rem 0 0.5rem;
  }

  .post-body p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--color-text-dark);
    margin-bottom: 1.25rem;
  }

  .post-body ul, .post-body ol {
    margin: 1rem 0 1.5rem 1.5rem;
  }

  .post-body li {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-dark);
    margin-bottom: 0.4rem;
  }

  .post-body strong {
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .post-body em {
    font-style: italic;
  }

  .post-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body a:hover {
    color: var(--color-accent-hover);
  }

  .post-body blockquote {
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--color-accent-glow);
    border-radius: 0 8px 8px 0;
  }

  .post-body blockquote p {
    font-size: 1rem;
    color: var(--color-text-dark);
    margin-bottom: 0;
  }

  .post-body code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875rem;
    background: var(--color-bg-warm);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .post-body pre {
    background: var(--color-bg-dark);
    color: var(--color-text-light);
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .post-body pre code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  /* Figures */
  .post-body figure {
    margin: 2rem 0;
  }

  .post-body figcaption {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
    font-style: italic;
  }

  /* Expandable sections */
  .post-body details {
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .post-body summary {
    padding: 0.875rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
    cursor: pointer;
    background: var(--color-accent-glow);
    transition: background 0.2s;
    list-style: none;
  }

  .post-body summary::-webkit-details-marker {
    display: none;
  }

  .post-body summary::before {
    content: '+ ';
    font-weight: 700;
  }

  .post-body details[open] summary::before {
    content: '- ';
  }

  .post-body summary:hover {
    background: rgba(var(--color-accent-rgb), 0.12);
  }

  .post-body details > div {
    padding: 1rem 1.25rem;
    font-size: 0.925rem;
  }

  .post-body details > div p {
    font-size: 0.925rem;
  }

  /* Idea blocks */
  .idea-block {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    border-left: 4px solid var(--color-accent);
  }

  .idea-block .idea-number {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .idea-block h4 {
    margin: 0 0 0.75rem 0;
  }

  .idea-block p {
    font-size: 0.95rem;
  }

  /* Tables */
  .post-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .post-body th {
    text-align: left;
    font-weight: 600;
    padding: 0.75rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text-dark);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-body td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-dark);
  }

  .post-body tr:hover td {
    background: var(--color-accent-glow);
  }

  /* Footnotes */
  .footnote {
    font-size: 0.75rem;
    vertical-align: super;
    color: var(--color-accent);
    font-weight: 600;
    cursor: help;
  }

  .footnotes-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footnotes-section h3 {
    font-size: 1rem;
  }

  .footnotes-section ol {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footnotes-section li {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* References */
  .references-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .references-section h3 {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .references-section ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .references-section li {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding: 0.4rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    line-height: 1.6;
  }

  /* Footer */
  .post-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 2rem;
  }

  .post-footer-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-back {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .post-meta-block {
      padding: 3rem 1.25rem 1.5rem;
    }

    .post-body {
      padding: 1.5rem 1.25rem 3rem;
    }
  }
</style>
