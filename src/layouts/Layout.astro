---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Vitor Reis | Solutions Architect - AI, Data & R&D",
  description = "Technology Professional with 10+ years experience. Specialized in building scalable AI systems and managing cross-continental engineering teams."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Vitor Eulalio Reis" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="preload" href="/me-560.jpeg" as="image" />
    <title>{title}</title>
    <script is:inline>
      (function(){
        var t={green:{a:'#10b981',h:'#059669',d:'#064e3b',r:'16,185,129',l:'#0e7f5a',k:'#34d399'},blue:{a:'#3b82f6',h:'#2563eb',d:'#1e3a5f',r:'59,130,246',l:'#2b6cb0',k:'#6ba3f5'},purple:{a:'#8a05be',h:'#6b00a8',d:'#3b0064',r:'138,5,190',l:'#8b24b2',k:'#b84de0'},yellow:{a:'#eab308',h:'#ca8a04',d:'#713f12',r:'234,179,8',l:'#866610',k:'#f0c23a'},orange:{a:'#f97316',h:'#ea580c',d:'#7c2d12',r:'249,115,22',l:'#c05709',k:'#fb923c'}};
        var c=localStorage.getItem('accent-color');
        var v=t[c];if(!v)return;
        var s=document.documentElement.style;
        s.setProperty('--color-accent',v.a);
        s.setProperty('--color-accent-hover',v.h);
        s.setProperty('--color-accent-dim',v.d);
        s.setProperty('--color-accent-rgb',v.r);
        s.setProperty('--color-accent-glow','rgba('+v.r+',0.15)');
        s.setProperty('--color-accent-on-light',v.l);
        s.setProperty('--color-accent-on-dark',v.k);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>

    <script>
      // Fullpage section scroll — desktop only (mobile sections exceed viewport height)
      const fpEnabled = window.matchMedia('(min-width: 769px)').matches;
      const fpSections = Array.from(document.querySelectorAll('main > section'));

      if (fpSections.length && fpEnabled) {
        let fpIndex = 0;
        let fpLocked = false;

        function fpNearest(): number {
          const y = window.scrollY;
          let best = 0;
          let bestDist = Infinity;
          for (let i = 0; i < fpSections.length; i++) {
            const d = Math.abs((fpSections[i] as HTMLElement).offsetTop - y);
            if (d < bestDist) { bestDist = d; best = i; }
          }
          return best;
        }

        function fpGo(i: number) {
          const idx = Math.max(0, Math.min(i, fpSections.length - 1));
          const target = (fpSections[idx] as HTMLElement).offsetTop;
          if (idx === fpIndex && Math.abs(window.scrollY - target) < 2) return;
          fpLocked = true;
          fpIndex = idx;
          window.scrollTo(0, target);
          setTimeout(() => { fpLocked = false; }, 200);
        }

        fpIndex = fpNearest();

        // Wheel — one section per scroll gesture
        window.addEventListener('wheel', (e) => {
          e.preventDefault();
          if (fpLocked) return;
          fpIndex = fpNearest();
          fpGo(fpIndex + (e.deltaY > 0 ? 1 : -1));
        }, { passive: false });

        // Touch — vertical swipes change section, horizontal pass through
        let fpTouchX = 0;
        let fpTouchY = 0;
        let fpTouchDir: 'v' | 'h' | null = null;

        window.addEventListener('touchstart', (e) => {
          fpTouchX = e.touches[0].clientX;
          fpTouchY = e.touches[0].clientY;
          fpTouchDir = null;
        }, { passive: true });

        window.addEventListener('touchmove', (e) => {
          if (!fpTouchDir) {
            const dx = Math.abs(e.touches[0].clientX - fpTouchX);
            const dy = Math.abs(e.touches[0].clientY - fpTouchY);
            if (dx + dy > 10) fpTouchDir = dy > dx ? 'v' : 'h';
          }
          if (fpTouchDir === 'v') e.preventDefault();
        }, { passive: false });

        window.addEventListener('touchend', (e) => {
          if (fpLocked || fpTouchDir !== 'v') return;
          const diff = fpTouchY - e.changedTouches[0].clientY;
          if (Math.abs(diff) < 30) return;
          fpIndex = fpNearest();
          fpGo(fpIndex + (diff > 0 ? 1 : -1));
        });

        // Keyboard
        window.addEventListener('keydown', (e) => {
          const tag = (document.activeElement?.tagName || '').toLowerCase();
          if (['input', 'textarea', 'select'].includes(tag)) return;
          if ((document.activeElement as HTMLElement)?.isContentEditable) return;
          if (fpLocked) return;

          const down = ['ArrowDown', 'PageDown', ' '];
          const up = ['ArrowUp', 'PageUp'];

          if (down.includes(e.key)) {
            e.preventDefault();
            fpIndex = fpNearest();
            fpGo(fpIndex + 1);
          } else if (up.includes(e.key)) {
            e.preventDefault();
            fpIndex = fpNearest();
            fpGo(fpIndex - 1);
          } else if (e.key === 'Home') {
            e.preventDefault();
            fpGo(0);
          } else if (e.key === 'End') {
            e.preventDefault();
            fpGo(fpSections.length - 1);
          }
        });

        // Hash link clicks (nav links, CTAs, etc.)
        document.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = (a as HTMLAnchorElement).getAttribute('href')!.slice(1);
            const idx = fpSections.findIndex(s => s.id === id);
            if (idx !== -1) {
              e.preventDefault();
              fpGo(idx);
            }
          });
        });

        // Handle initial hash on page load
        if (location.hash) {
          const id = location.hash.slice(1);
          const idx = fpSections.findIndex(s => s.id === id);
          if (idx !== -1) requestAnimationFrame(() => fpGo(idx));
        }
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
